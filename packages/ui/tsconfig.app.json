{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist-types",
    "tsBuildInfoFile": "./dist-types/.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "node"]
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*"],
  "exclude": ["dist", "dist-types", "node_modules"]
}
