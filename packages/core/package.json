{
  "name": "@anvil/core",
  "version": "0.1.0",
  "description": "Anvil shared core: frozen Zod schemas + inferred types for eval suites and run results.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/core"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  }
}
